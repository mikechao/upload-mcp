{
  "name": "file-upload-mcp-server",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "A Model Context Protocol external app that demonstrates file upload functionality in MCP and ChatGPT.",
  "scripts": {
    "build:widget": "pnpm build:widget:chatgpt && pnpm build:widget:mcp",
    "build:widget:chatgpt": "WIDGET_ENTRY=chatgpt-app.html WIDGET_EMPTY_OUT_DIR=true vite build --config src/web/vite.config.ts",
    "build:widget:mcp": "WIDGET_ENTRY=mcp-app.html WIDGET_EMPTY_OUT_DIR=false vite build --config src/web/vite.config.ts",
    "build": "pnpm build:widget && tsc",
    "dev": "pnpm build:widget && tsx src/server.ts",
    "start": "pnpm build && node dist/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.1.2",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@types/cors": "^2.8.19",
    "cors": "^2.8.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "esbuild": "^0.27.2",
    "express": "^5.2.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
